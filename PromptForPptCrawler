### PptChunk.java
@Data @Builder
public class PptChunk {
    private String chunkId;                 // UUID
    private String text;                    // assembled slide text
    private String enrichedText;            // with context prefix
    private int slideNumber;
    private String slideTitle;
    private String deckTitle;
    private int chunkIndex;
    private int totalChunks;
    private String prevChunkId;
    private String nextChunkId;
    private String sourceFile;
    private boolean includesSpeakerNotes;
    private boolean isTable;
    private int tokenCount;

    public TextSegment toTextSegment() {
        Metadata metadata = Metadata.from(Map.of(
            "source",       sourceFile,
            "slide",        String.valueOf(slideNumber),
            "slideTitle",   slideTitle != null ? slideTitle : "",
            "deckTitle",    deckTitle != null ? deckTitle : "",
            "chunkId",      chunkId,
            "prevChunk",    prevChunkId != null ? prevChunkId : "",
            "nextChunk",    nextChunkId != null ? nextChunkId : "",
            "hasNotes",     String.valueOf(includesSpeakerNotes)
        ));
        return TextSegment.from(
            enrichedText != null ? enrichedText : text, metadata
        );
    }
}

